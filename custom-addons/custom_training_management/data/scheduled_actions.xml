<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- Weekly Reminder Scheduled Action (Section 8.2) -->
    <record id="ir_cron_weekly_training_reminder" model="ir.cron">
        <field name="name">Training Management: Weekly Reminder Emails</field>
        <field name="model_id" ref="model_training_attendee"/>
        <field name="state">code</field>
        <field name="code">model.send_weekly_reminders()</field>
        <field name="interval_number">1</field>
        <field name="interval_type">weeks</field>
        <field name="numbercall">-1</field>
        <field name="doall" eval="False"/>
        <field name="active" eval="True"/>
        <field name="nextcall" eval="(DateTime.now() + relativedelta(days=1)).strftime('%Y-%m-%d 08:00:00')"/>
    </record>

    <record id="ir_cron_mark_overdue_trainings" model="ir.cron">
        <field name="name">Mark Overdue Trainings</field>
        <field name="model_id" ref="model_training_attendee"/>
        <field name="state">code</field>
        <field name="code">model.action_mark_overdue()</field>
        <field name="interval_number">3</field>
        <field name="interval_type">days</field>
        <field name="numbercall">-1</field>
        <field name="active" eval="True"/>
    </record>

</odoo>