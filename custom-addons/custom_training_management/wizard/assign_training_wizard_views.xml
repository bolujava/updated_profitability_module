<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_assign_training_wizard_form" model="ir.ui.view">
        <field name="name">assign.training.wizard.form</field>
        <field name="model">assign.training.wizard</field>
        <field name="arch" type="xml">
            <form>
                <sheet>
                    <group>
                        <field name="course_id" options="{'no_create': True}"/>
                    </group>

                    <group>
                        <field name="assignment_type" widget="radio"/>
                    </group>

                    <group attrs="{'invisible': [('assignment_type', '!=', 'individual')]}">
                        <field name="employee_ids" widget="many2many_tags"
                               options="{'no_create': True}"
                               domain="[]"/>
                    </group>

                    <group attrs="{'invisible': [('assignment_type', '!=', 'department')]}">
                        <field name="department_ids" widget="many2many_tags"
                               options="{'no_create': True}"/>
                    </group>

                    <group attrs="{'invisible': [('assignment_type', '!=', 'company')]}">
                        <div class="o_form_label text-info">
                            Training will be assigned to ALL employees in the company.
                        </div>
                    </group>

                    <group>
                        <group>
                            <field name="date_start"/>
                        </group>
                        <group>
                            <field name="date_end"/>
                        </group>
                    </group>

                    <group>
                        <field name="priority" widget="priority"/>
                    </group>
                </sheet>

                <footer>
                    <button name="action_assign" type="object" string="Assign Training" class="btn-primary"/>
                    <button special="cancel" string="Cancel"/>
                </footer>
            </form>
        </field>
    </record>

    <record id="action_assign_training_wizard" model="ir.actions.act_window">
        <field name="name">Assign Training</field>
        <field name="res_model">assign.training.wizard</field>
        <field name="view_mode">form</field>
        <field name="target">new</field>
        <field name="context">{'default_course_id': active_id}</field>
    </record>
</odoo>