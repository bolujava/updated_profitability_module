<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- Kanban View for Training Attendees -->
    <record id="view_training_attendee_kanban" model="ir.ui.view">
        <field name="name">training.attendee.kanban</field>
        <field name="model">training.attendee</field>
        <field name="arch" type="xml">
            <kanban default_group_by="stage_id"
                    class="o_kanban_small_column o_kanban_project_tasks"
                    color="kanban_color">

                <!-- Fields used in Kanban -->
                <field name="stage_id"/>
                <field name="kanban_color"/>
                <field name="employee_id"/>
                <field name="course_id"/>
                <field name="training_code"/>
                <field name="priority"/>
                <field name="state"/>
                <field name="completion_percentage"/>
                <field name="activity_ids"/>

                <templates>
                    <t t-name="kanban-box">
                        <div class="oe_kanban_global_click oe_kanban_card">
                            <div class="oe_kanban_content">

                                <!-- TOP: Employee Name -->
                                <div class="o_kanban_record_top">
                                    <strong class="o_kanban_record_title">
                                        <field name="employee_id"/>
                                    </strong>
                                </div>

                                <!-- BODY: Training Code + Progress -->
                                <div class="o_kanban_record_body">
                                    <div class="text-muted mb-1">
                                        <t t-esc="record.training_code.raw_value"/>
                                    </div>
                                    <div class="text-muted">
                                        <field name="course_id"/>
                                    </div>
                                    <div class="mt-2">
                                        <field name="completion_percentage" widget="progressbar"/>
                                    </div>
                                </div>

                                <!-- BOTTOM: Priority, Activities, Avatar -->
                                <div class="o_kanban_record_bottom">
                                    <div class="oe_kanban_bottom_left">
                                        <field name="priority" widget="priority"/>
                                        <field name="activity_ids" widget="kanban_activity"/>
                                    </div>
                                    <div class="oe_kanban_bottom_right">
                                        <img t-att-src="kanban_image('hr.employee', 'image_128', record.employee_id.raw_value)"
                                             class="oe_kanban_avatar"
                                             alt="Avatar"/>
                                    </div>
                                </div>

                            </div>
                        </div>
                    </t>
                </templates>

            </kanban>
        </field>
    </record>

    <!-- Training Stages -->
    <record id="training_stage_not_started" model="training.stage">
        <field name="name">Not Started</field>
        <field name="sequence">1</field>
    </record>

    <record id="training_stage_in_progress" model="training.stage">
        <field name="name">In Progress</field>
        <field name="sequence">2</field>
    </record>

    <record id="training_stage_completed" model="training.stage">
        <field name="name">Completed</field>
        <field name="sequence">3</field>
        <field name="fold">True</field>
    </record>

    <record id="training_stage_overdue" model="training.stage">
        <field name="name">Overdue</field>
        <field name="sequence">4</field>
    </record>
