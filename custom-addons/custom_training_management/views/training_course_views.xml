<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- Tree View -->
    <record id="view_training_course_tree" model="ir.ui.view">
        <field name="name">training.course.tree</field>
        <field name="model">training.course</field>
        <field name="arch" type="xml">
            <tree>
                <field name="name"/>
                <field name="training_code"/>
                <field name="category_id"/>
                <field name="is_mandatory"/>
                <field name="estimated_duration"/>
                <field name="state" widget="badge" decoration-success="state == 'published'" decoration-warning="state == 'draft'" decoration-danger="state == 'archived'"/>
                <field name="assigned_count"/>
                <field name="completed_count"/>
                <field name="completion_rate"/>
            </tree>
        </field>
    </record>

    <!-- Add this to your training_course_views.xml -->
    <record id="view_training_course_tree_inherit" model="ir.ui.view">
        <field name="name">training.course.tree.inherit</field>
        <field name="model">training.course</field>
        <field name="inherit_id" ref="view_training_course_tree"/>
        <field name="arch" type="xml">
            <xpath expr="//tree" position="attributes">
                <attribute name="import">1</attribute>
            </xpath>
        </field>
    </record>

    <!-- Form View - Training Creation (Section 7.1) -->
    <record id="view_training_course_form" model="ir.ui.view">
        <field name="name">training.course.form</field>
        <field name="model">training.course</field>
        <field name="arch" type="xml">
            <form>
                <header>
                    <button name="action_publish" type="object" string="Publish" class="btn-primary" states="draft"/>
                    <button name="action_draft" type="object" string="Set to Draft" states="published"/>
                    <button name="action_archive" type="object" string="Archive" states="published"/>
                    <button name="%(action_assign_training_wizard)d" type="action" string="Assign Training" class="btn-primary" states="published"/>
                    <field name="state" widget="statusbar" statusbar_visible="draft,published,archived"/>
                </header>
                <sheet>
                    <div class="oe_title">
                        <h1>
                            <field name="name" placeholder="e.g., Azure Training..."/>
                        </h1>
                         <h2>
                            <field name="training_code" class="text-muted" readonly="1"/>
                        </h2>
                    </div>
                    <group>
                        <group>
                            <field name="category_id" widget="selection"/>
                            <field name="is_mandatory" widget="radio"/>
                            <field name="estimated_duration"/>
                        </group>
                        <group>
<!--                            <field name="company_wide" groups="custom_training_management.group_training_admin"/>-->
                            <field name="training_code" readonly="1"/>
                            <field name="created_by" readonly="1"/>
                            <field name="published_date" readonly="1"/>
                        </group>
                    </group>

                    <notebook>
                        <page string="Description">
                            <field name="description" widget="html"/>
                        </page>

                        <page string="Resources">
                            <group>
                                <field name="resource_file" filename="resource_filename"/>
                                <field name="resource_filename" invisible="1"/>
                                <field name="resource_url" widget="url"/>
                            </group>
                        </page>

                        <page string="Attendees">
                            <field name="attendee_ids">
                                <tree>
                                    <field name="employee_id"/>
                                    <field name="department_id"/>
                                    <field name="date_start"/>
                                    <field name="date_end"/>
                                    <field name="state" widget="badge"/>
                                    <field name="completion_percentage"/>
                                    <field name="certificate_uploaded"/>
                                </tree>
                            </field>
                        </page>

                        <page string="Statistics">
                            <group>
                                <field name="assigned_count"/>
                                <field name="completed_count"/>
                                <field name="completion_rate"/>
                            </group>
                        </page>
                    </notebook>
                </sheet>

                <div class="oe_chatter">
                    <field name="message_follower_ids"/>
                    <field name="activity_ids"/>
                    <field name="message_ids"/>
                </div>
            </form>
        </field>
    </record>

    <!-- Search View -->
    <record id="view_training_course_search" model="ir.ui.view">
        <field name="name">training.course.search</field>
        <field name="model">training.course</field>
        <field name="arch" type="xml">
            <search>
                <field name="name"/>
                <field name="category_id"/>
                <filter name="filter_published" string="Published" domain="[('state', '=', 'published')]"/>
                <filter name="filter_mandatory" string="Mandatory" domain="[('is_mandatory', '=', 'mandatory')]"/>
                <separator/>
                <filter name="group_category" string="Category" context="{'group_by': 'category_id'}"/>
                <filter name="group_state" string="Status" context="{'group_by': 'state'}"/>
            </search>
        </field>
    </record>

    <!-- Action -->
    <record id="action_training_course" model="ir.actions.act_window">
        <field name="name">Trainings</field>
        <field name="res_model">training.course</field>
        <field name="view_mode">tree,form</field>
        <field name="context">{'search_default_filter_published': 1}</field>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                Create your first training program!
            </p>
            <p>
                Trainings can be assigned to employees individually, by department, or company-wide.
            </p>
        </field>
    </record>
</odoo>