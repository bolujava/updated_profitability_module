<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- People Services Dashboard - Pivot View -->
    <record id="view_training_dashboard_pivot" model="ir.ui.view">
        <field name="name">training.dashboard.pivot</field>
        <field name="model">training.attendee</field>
        <field name="arch" type="xml">
            <pivot string="Training Analysis">
                <field name="state" type="row"/>
                <field name="department_id" type="col"/>
                <field name="course_id" type="row"/>
                <field name="employee_id" type="row"/>
                <field name="assignment_type" type="col"/>
                <field name="certificate_uploaded" type="col"/>
                <field name="training_code" type="row"/>
            </pivot>
        </field>
    </record>

    <!-- Graph View for Completion Rates -->
    <record id="view_training_dashboard_graph" model="ir.ui.view">
        <field name="name">training.dashboard.graph</field>
        <field name="model">training.attendee</field>
        <field name="arch" type="xml">
            <graph string="Training Completion">
                <field name="department_id" type="row"/>
                <field name="state" type="col"/>
            </graph>
        </field>
    </record>

