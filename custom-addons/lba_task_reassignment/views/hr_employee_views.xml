<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- Add reassign button to employee form -->
    <record id="view_employee_form_reassign" model="ir.ui.view">
        <field name="name">lba.employee.form.reassign</field>
        <field name="model">hr.employee</field>
        <field name="inherit_id" ref="hr.view_employee_form"/>
        <field name="arch" type="xml">
            <!-- Add required fields as invisible (needed for attrs) -->
            <xpath expr="//field[@name='name']" position="after">
                <field name="can_reassign_tasks" invisible="1"/>
                <field name="assigned_task_count" invisible="1"/>
            </xpath>

            <!-- Add button to button box -->
            <xpath expr="//div[@name='button_box']" position="inside">
                <button name="action_reassign_employee_tasks"
                        type="object"
                        class="oe_stat_button"
                        icon="fa-exchange"
                        groups="lba_task_reassignment.group_task_reassignment_pmo,
                                lba_task_reassignment.group_task_reassignment_pm,
                                lba_task_reassignment.group_task_reassignment_dept_mgr,
                                lba_task_reassignment.group_task_reassignment_team_lead"
                        attrs="{'invisible': [('can_reassign_tasks', '=', False)]}">
                    <div class="o_stat_info">
                        <field name="assigned_task_count" widget="statinfo" string="Tasks"/>
                        <span class="o_stat_text">Reassign Tasks</span>
                    </div>
                </button>
            </xpath>
        </field>
    </record>
</odoo>