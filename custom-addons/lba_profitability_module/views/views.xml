        <record id="view_task_form_inherit_profitability_fields" model="ir.ui.view">
            <field name="name">project.task.form.inherit.profitability.fields</field>
            <field name="model">project.task</field>
            <field name="inherit_id" ref="project.view_task_form2"/>
            <field name="arch" type="xml">
                <data>
                    <xpath expr="//field[@name='project_id']" position="after">
                        <field name="job_rate_id"
                               options="{'no_create': True, 'no_open': True}"
                               placeholder="Select Resource (e.g. Machine Learning Engineer)"/>
                        <field name="assigned_employee_ids"
                               widget="many2many_tags"
                               options="{'no_create': True}"
                               placeholder="Assign employees..."/>
                    </xpath>

                    <xpath expr="//field[@name='user_id'] | //field[@name='user_ids'] | //field[@name='assignees_ids']" position="attributes">
                        <attribute name="invisible">1</attribute>
                    </xpath>

                    <xpath expr="//field[@name='date_deadline']" position="before">
                        <field name="task_starting_date"/>
                    </xpath>

                    <xpath expr="//field[@name='date_deadline']" position="after">
                        <field name="planned_hours" widget="float" string="Planned Duration in Hours"/>
                    </xpath>
                </data>
            </field>
        </record>

        <!-- Search View for Project Planning Enhancement and Extension     -->
        <record id="view_planning_slot_search_inherit" model="ir.ui.view">
            <field name="name">planning.slot.search.inherit</field>
            <field name="model">planning.slot</field>
            <field name="inherit_id" ref="planning.planning_view_search"/> <!-- Reference the original search view -->
