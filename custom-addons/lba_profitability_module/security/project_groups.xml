<?xml version="1.0" encoding="UTF-8"?>
<odoo>
    <data noupdate="0">
        <record id="group_project_manager" model="res.groups">
            <field name="name">Project Enhancement-Project Manager</field>
            <field name="category_id" ref="base.module_category_hidden"/>
        </record>

        <record id="group_team_lead" model="res.groups">
            <field name="name">Project Enhancement-Team Lead</field>
            <field name="category_id" ref="base.module_category_hidden"/>
        </record>

        <record id="group_department_manager" model="res.groups">
            <field name="name">Project Enhancement-Department Manager</field>
            <field name="category_id" ref="base.module_category_hidden"/>
        </record>

        <record id="group_pmo" model="res.groups">
            <field name="name">Project Enhancement-PMO</field>
            <field name="category_id" ref="base.module_category_hidden"/>
        </record>

        <!-- ===== CATEGORY ===== -->
        <record id="category_project_restrictions" model="ir.module.category">
            <field name="name">Project View Access Control</field>
        </record>

        <!-- ===== FULL ACCESS GROUP (NO implied_ids) ===== -->
        <record id="group_project_full_access" model="res.groups">
            <field name="name">See Full Project Details (Unrestricted)</field>
            <field name="category_id" ref="category_project_restrictions"/>
            <!-- NO implied_ids - users in this group will NOT become admins -->
        </record>

        <!-- ===== PROJECT RULES ===== -->

        <!-- PMO & Project Manager: Full Admin Access -->
        <record id="project_project_manager_all_rule" model="ir.rule">
            <field name="name">Project: Manager/PMO All</field>
            <field name="model_id" ref="project.model_project_project"/>
            <field name="global" eval="False"/>
            <field name="domain_force">[(1, '=', 1)]</field>
            <field name="groups" eval="[(6, 0, [ref('lba_profitability_module.group_project_manager'), ref('lba_profitability_module.group_pmo')])]"/>
        </record>

        <!-- Full Access Group: Can see all projects but NOT administrators -->
        <record id="project_project_full_access_rule" model="ir.rule">
            <field name="name">Project: Full Access (Unrestricted View)</field>
            <field name="model_id" ref="project.model_project_project"/>
            <field name="groups" eval="[(4, ref('group_project_full_access'))]"/>
            <field name="global" eval="False"/>
            <field name="domain_force">[(1, '=', 1)]</field>
            <field name="perm_read" eval="True"/>
            <field name="perm_write" eval="True"/>
            <field name="perm_create" eval="False"/>
            <field name="perm_unlink" eval="False"/>
        </record>

        <!-- Team Lead: Projects where they are Team Lead -->
        <record id="project_project_team_lead_rule" model="ir.rule">
            <field name="name">Project: Team Lead Own Projects</field>
            <field name="model_id" ref="project.model_project_project"/>
            <field name="global" eval="False"/>
            <field name="domain_force">[
                ('team_lead_id', '=', user.employee_id.id)
            ]</field>
            <field name="groups" eval="[(4, ref('lba_profitability_module.group_team_lead'))]"/>
            <field name="perm_read" eval="True"/>
            <field name="perm_write" eval="True"/>
            <field name="perm_create" eval="False"/>
            <field name="perm_unlink" eval="False"/>
        </record>

        <!-- Department Manager: Projects in their department -->
        <record id="project_project_dept_manager_rule" model="ir.rule">
            <field name="name">Project: Department Manager Own Department</field>
            <field name="model_id" ref="project.model_project_project"/>
            <field name="global" eval="False"/>
            <field name="domain_force">[
                '|',
                ('department_manager_id', '=', user.employee_id.id),
                ('department_id.manager_id', '=', user.employee_id.id)
            ]</field>
            <field name="groups" eval="[(4, ref('lba_profitability_module.group_department_manager'))]"/>
            <field name="perm_read" eval="True"/>
            <field name="perm_write" eval="True"/>
            <field name="perm_create" eval="False"/>
            <field name="perm_unlink" eval="False"/>
        </record>

        <!-- Sales Visibility Rule -->
        <record id="project_project_sales_visibility_rule" model="ir.rule">
            <field name="name">Project: Sales Visibility</field>
            <field name="model_id" ref="project.model_project_project"/>
            <field name="global" eval="False"/>
            <field name="domain_force">
                ['|', '|', '|',
                    ('create_uid', '=', user.id),
                    ('sale_order_id.create_uid', '=', user.id),
                    ('sale_order_id.user_id', '=', user.id),
                    ('sale_order_id.team_id', 'in', user.sale_team_id.ids)
                ]
            </field>
            <field name="groups" eval="[(4, ref('sales_team.group_sale_salesman_all_leads'))]"/>
            <field name="perm_write" eval="True"/>
        </record>

