<?xml version="1.0" encoding="UTF-8"?>
<odoo>
    <data noupdate="0">
        <!-- Project Manager Group -->
        <record id="group_project_manager" model="res.groups">
            <field name="name">Project Enhancement-Project Manager</field>
            <field name="category_id" ref="base.module_category_hidden"/>
            <field name="implied_ids" eval="[(4, ref('base.group_user'))]"/>
        </record>

        <!-- Team Lead Group -->
        <record id="group_team_lead" model="res.groups">
            <field name="name">Project Enhancement-Team Lead</field>
            <field name="category_id" ref="base.module_category_hidden"/>
            <field name="implied_ids" eval="[(4, ref('base.group_user'))]"/>
        </record>

        <!-- Department Manager Group -->
        <record id="group_department_manager" model="res.groups">
            <field name="name">Project Enhancement-Department Manager</field>
            <field name="category_id" ref="base.module_category_hidden"/>
            <field name="implied_ids" eval="[(4, ref('base.group_user'))]"/>
        </record>

        <!-- PMO Group -->
        <record id="group_pmo" model="res.groups">
            <field name="name">Project Enhancement-PMO</field>
            <field name="category_id" ref="base.module_category_hidden"/>
            <field name="implied_ids" eval="[(4, ref('base.group_user'))]"/>
        </record>

        <record id="project_project_manager_all_rule" model="ir.rule">
            <field name="name">Project: Manager/PMO All</field>
            <field name="model_id" ref="project.model_project_project"/>
            <field name="global" eval="False"/>
            <field name="domain_force">[(1, '=', 1)]</field>
            <field name="groups" eval="[(6, 0, [ref('lba_profitability_module.group_project_manager'), ref('lba_profitability_module.group_pmo')])]"/>
        </record>

        <record id="category_project_restrictions" model="ir.module.category">
            <field name="name">Project View Access Control</field>
        </record>

        <record id="group_project_full_access" model="res.groups">
            <field name="name">See Full Project Details (Unrestricted)</field>
            <field name="category_id" ref="category_project_restrictions"/>
            <field name="implied_ids" eval="[(4, ref('project.group_project_manager'))]"/>
        </record>
    </data>
</odoo>