        </record>

        <!-- Full Access Rule for Managers & PMO -->
        <record id="project_project_manager_all_rule" model="ir.rule">
            <field name="name">Project: Manager/PMO All</field>
            <field name="model_id" ref="project.model_project_project"/>
            <field name="global" eval="False"/>
            <field name="domain_force">[(1, '=', 1)]</field>
            <field name="groups" eval="[(6, 0, [ref('lba_profitability_module.group_project_manager'), ref('lba_profitability_module.group_pmo')])]"/>
        </record>

        <record id="project_project_sales_visibility_rule" model="ir.rule">
            <field name="name">Project: Sales Visibility</field>
            <field name="model_id" ref="project.model_project_project"/>
            <field name="global" eval="False"/>
            <field name="domain_force">
                ['|', '|', '|',
                    ('create_uid', '=', user.id),
                    ('sale_order_id.create_uid', '=', user.id),
                    ('sale_order_id.user_id', '=', user.id),
                    ('sale_order_id.team_id', 'in', user.sale_team_id.ids)
                ]
            </field>
            <field name="groups" eval="[(4, ref('sales_team.group_sale_salesman_all_leads'))]"/>
            <field name="perm_write" eval="True"/>
        </record>


